<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Space Storm Invaders</title>
  <style>
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      font-family: Arial, sans-serif;
      background: radial-gradient(circle at top, #111b38 0%, #060816 100%);
      color: #f8fafc;
    }
    .wrap {
      width: min(94vw, 500px);
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 16px 48px rgba(0,0,0,0.35);
      border: 2px solid rgba(255,255,255,0.12);
      background: rgba(5, 8, 25, 0.95);
    }
    .hud {
      display: flex;
      justify-content: space-between;
      padding: 12px 14px;
      font-weight: 700;
      background: rgba(255,255,255,0.06);
      font-size: 0.95rem;
    }
    canvas {
      display: block;
      width: 100%;
      height: auto;
      cursor: pointer;
      touch-action: manipulation;
      background: linear-gradient(180deg, #07111f 0%, #0f2842 100%);
    }
    .hint {
      padding: 10px 14px 14px;
      text-align: center;
      color: #b7c8e2;
      font-size: 0.92rem;
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="hud">
      <div>Score: <span id="score">0</span></div>
      <div>Lives: <span id="lives">3</span></div>
      <div>Boss: <span id="bossText">None</span></div>
    </div>
    <canvas id="game" width="500" height="640"></canvas>
    <div class="hint">Move with ← → or A / D. Shoot with Space. Tap to start and flap-like fire.</div>
  </div>

  <script>
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');
    const scoreEl = document.getElementById('score');
    const livesEl = document.getElementById('lives');
    const bossEl = document.getElementById('bossText');

    const W = canvas.width;
    const H = canvas.height;
    const keys = {};

    let player;
    let bullets = [];
    let enemyBullets = [];
    let enemies = [];
    let powerUps = [];
    let bosses = [];
    let stars = [];
    let score = 0;
    let lives = 3;
    let gameState = 'ready';
    let enemyDir = 1;
    let frame = 0;
    let bossTimer = 0;
    let stormTimer = 0;

    function rand(min, max) {
      return Math.random() * (max - min) + min;
    }

    function resetStars() {
      stars = [];
      for (let i = 0; i < 90; i += 1) {
        stars.push({
          x: Math.random() * W,
          y: Math.random() * H,
          r: Math.random() * 1.8 + 0.4,
          speed: Math.random() * 0.6 + 0.2
        });
      }
    }

    function resetGame() {
      player = {
        x: W / 2,
        y: H - 50,
        w: 28,
        h: 24,
        speed: 5,
        cooldown: 0,
        power: 'none',
        powerTimer: 0,
        shieldTimer: 0
      };
      bullets = [];
      enemyBullets = [];
      enemies = [];
      powerUps = [];
      bosses = [];
      score = 0;
      lives = 3;
      enemyDir = 1;
      frame = 0;
      bossTimer = 0;
      stormTimer = 0;
      gameState = 'ready';
      buildEnemies();
      updateHud();
    }

    function updateHud() {
      scoreEl.textContent = score;
      livesEl.textContent = lives;
      bossEl.textContent = bosses.length ? 'Active' : 'None';
    }

    function buildEnemies() {
      enemies = [];
      const rows = 4;
      const cols = 7;
      const startX = 70;
      const startY = 90;
      const gapX = 54;
      const gapY = 52;
      for (let r = 0; r < rows; r += 1) {
        for (let c = 0; c < cols; c += 1) {
          enemies.push({
            x: startX + c * gapX,
            y: startY + r * gapY,
            w: 30,
            h: 24,
            alive: true
          });
        }
      }
    }

    function startGame() {
      if (gameState === 'over') {
        resetGame();
      }
      gameState = 'playing';
    }

    function shoot() {
      if (gameState !== 'playing') return;
      if (player.cooldown > 0) return;

      const patterns = player.power === 'spread'
        ? [[-0.35, -10], [0, -10], [0.35, -10]]
        : [[0, -10]];

      patterns.forEach(([dx, dy]) => {
        bullets.push({ x: player.x, y: player.y - 12, vx: dx * 6.6, vy: dy, r: 3.4 });
      });

      player.cooldown = player.power === 'rapid' ? 8 : 12;
    }

    function spawnBoss() {
      bosses.push({ x: W / 2 - 70, y: 48, w: 140, h: 44, hp: 80 + Math.floor(score / 10), shootCooldown: 40, dir: 1 });
    }

    function spawnPowerStorm() {
      for (let i = 0; i < 1000; i += 1) {
        const types = ['shield', 'rapid', 'spread'];
        powerUps.push({
          x: Math.random() * W,
          y: -20 - Math.random() * 80,
          vy: 1.8 + Math.random() * 2.2,
          vx: (Math.random() - 0.5) * 1.2,
          r: 8 + Math.random() * 3,
          type: types[Math.floor(Math.random() * types.length)]
        });
      }
    }

    function applyPower(type) {
      if (type === 'shield') {
        player.shieldTimer = 360;
      } else {
        player.power = type;
        player.powerTimer = 420;
      }
    }

    function update() {
      if (gameState !== 'playing') return;

      frame += 1;
      stormTimer += 1;
      bossTimer += 1;

      if (stormTimer > 300) {
        spawnPowerStorm();
        stormTimer = 0;
      }

      if (bossTimer > 1800 && bosses.length === 0) {
        spawnBoss();
        bossTimer = 0;
      }

      if (keys.ArrowLeft || keys.a) player.x -= player.speed;
      if (keys.ArrowRight || keys.d) player.x += player.speed;
      player.x = Math.max(20, Math.min(W - 20, player.x));

      if (player.cooldown > 0) player.cooldown -= 1;
      if (player.powerTimer > 0) {
        player.powerTimer -= 1;
        if (player.powerTimer <= 0) player.power = 'none';
      }
      if (player.shieldTimer > 0) {
        player.shieldTimer -= 1;
      }

      if (keys.Space) shoot();

      bullets.forEach((b) => {
        b.x += b.vx;
        b.y += b.vy;
      });
      bullets = bullets.filter((b) => b.y > -30 && b.x > -30 && b.x < W + 30);

      if (frame % 2 === 0) {
        enemies.forEach((e) => {
          e.x += enemyDir * 1.6;
        });
        let hitBoundary = enemies.some((e) => e.x < 20 || e.x + e.w > W - 20);
        if (hitBoundary) {
          enemyDir *= -1;
          enemies.forEach((e) => {
            e.y += 18;
          });
        }
      }

      if (enemies.length && enemies.some((e) => e.y + e.h > H - 100)) {
        lives = 0;
        gameState = 'over';
      }

      if (Math.random() < 0.016 && enemies.length) {
        const shooter = enemies[Math.floor(Math.random() * enemies.length)];
        enemyBullets.push({ x: shooter.x + shooter.w / 2, y: shooter.y + shooter.h, vy: 3 + Math.random() * 1.2, r: 4 });
      }

      enemyBullets.forEach((b) => {
        b.y += b.vy;
      });
      enemyBullets = enemyBullets.filter((b) => b.y < H + 20);

      bosses.forEach((boss) => {
        boss.x += boss.dir * 1.3;
        if (boss.x < 30 || boss.x + boss.w > W - 30) boss.dir *= -1;
        boss.shootCooldown -= 1;
        if (boss.shootCooldown <= 0) {
          enemyBullets.push({ x: boss.x + 50, y: boss.y + 40, vy: 4.2, r: 6 });
          enemyBullets.push({ x: boss.x + 90, y: boss.y + 40, vy: 4.2, r: 6 });
          boss.shootCooldown = 46;
        }
      });

      powerUps.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.008;
      });
      powerUps = powerUps.filter((p) => p.y < H + 30 && p.x > -30 && p.x < W + 30);

      for (let i = bullets.length - 1; i >= 0; i -= 1) {
        const b = bullets[i];
        for (let j = enemies.length - 1; j >= 0; j -= 1) {
          const e = enemies[j];
          if (b.x > e.x && b.x < e.x + e.w && b.y > e.y && b.y < e.y + e.h) {
            bullets.splice(i, 1);
            enemies.splice(j, 1);
            score += 5;
            if (Math.random() < 0.22) {
              powerUps.push({ x: e.x + e.w / 2, y: e.y, vy: 1.2 + Math.random() * 1.4, vx: (Math.random() - 0.5) * 1.6, r: 8, type: ['shield', 'rapid', 'spread'][Math.floor(Math.random() * 3)] });
            }
            updateHud();
            break;
          }
        }
        if (i < bullets.length) {
          continue;
        }
        for (let j = bosses.length - 1; j >= 0; j -= 1) {
          const boss = bosses[j];
          if (b.x > boss.x && b.x < boss.x + boss.w && b.y > boss.y && b.y < boss.y + boss.h) {
            boss.hp -= 1;
            bullets.splice(i, 1);
            score += 2;
            updateHud();
            if (boss.hp <= 0) {
              bosses.splice(j, 1);
              score += 50;
              updateHud();
            }
            break;
          }
        }
      }

      for (let i = enemyBullets.length - 1; i >= 0; i -= 1) {
        const b = enemyBullets[i];
        if (b.x > player.x - 16 && b.x < player.x + 16 && b.y > player.y - 18 && b.y < player.y + 18) {
          enemyBullets.splice(i, 1);
          if (player.shieldTimer > 0) {
            player.shieldTimer = 0;
          } else {
            lives -= 1;
            updateHud();
          }
          if (lives <= 0) {
            gameState = 'over';
          }
        }
      }

      for (let i = powerUps.length - 1; i >= 0; i -= 1) {
        const p = powerUps[i];
        if (p.x > player.x - 20 && p.x < player.x + 20 && p.y > player.y - 20 && p.y < player.y + 20) {
          applyPower(p.type);
          powerUps.splice(i, 1);
        }
      }

      stars.forEach((s) => {
        s.y += s.speed;
        if (s.y > H) {
          s.y = -2;
          s.x = Math.random() * W;
        }
      });
    }

    function drawBackground() {
      const sky = ctx.createLinearGradient(0, 0, 0, H);
      sky.addColorStop(0, '#06111f');
      sky.addColorStop(0.5, '#0d2340');
      sky.addColorStop(1, '#163b5a');
      ctx.fillStyle = sky;
      ctx.fillRect(0, 0, W, H);

      stars.forEach((s) => {
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.95)';
        ctx.fill();
      });

      ctx.fillStyle = 'rgba(255,255,255,0.08)';
      ctx.fillRect(0, H - 90, W, 90);
    }

    function drawPlayer() {
      ctx.save();
      ctx.translate(player.x, player.y);
      ctx.fillStyle = '#4ade80';
      ctx.beginPath();
      ctx.moveTo(0, -18);
      ctx.lineTo(14, 10);
      ctx.lineTo(0, 6);
      ctx.lineTo(-14, 10);
      ctx.closePath();
      ctx.fill();
      ctx.fillStyle = '#f8fafc';
      ctx.fillRect(-4, -4, 8, 8);
      if (player.shieldTimer > 0) {
        ctx.strokeStyle = '#38bdf8';
        ctx.lineWidth = 3;
        ctx.beginPath();
        ctx.arc(0, 0, 24, 0, Math.PI * 2);
        ctx.stroke();
      }
      ctx.restore();
    }

    function drawBullets() {
      ctx.fillStyle = '#f8fafc';
      bullets.forEach((b) => {
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
        ctx.fill();
      });
      ctx.fillStyle = '#fb7185';
      enemyBullets.forEach((b) => {
        ctx.beginPath();
        ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
        ctx.fill();
      });
    }

    function drawEnemies() {
      enemies.forEach((e) => {
        ctx.fillStyle = '#f59e0b';
        ctx.fillRect(e.x, e.y, e.w, e.h);
        ctx.fillStyle = '#ef4444';
        ctx.fillRect(e.x + 6, e.y + 6, e.w - 12, 6);
      });
    }

    function drawBosses() {
      bosses.forEach((boss) => {
        ctx.fillStyle = '#8b5cf6';
        ctx.fillRect(boss.x, boss.y, boss.w, boss.h);
        ctx.fillStyle = '#f43f5e';
        ctx.fillRect(boss.x + 20, boss.y + 12, boss.w - 40, 10);
        ctx.fillText(`HP ${boss.hp}`, boss.x + 26, boss.y + 30);
      });
    }

    function drawPowerUps() {
      powerUps.forEach((p) => {
        let color = '#34d399';
        if (p.type === 'rapid') color = '#fb923c';
        if (p.type === 'spread') color = '#f472b6';
        if (p.type === 'shield') color = '#38bdf8';
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fill();
      });
    }

    function drawOverlay() {
      if (gameState === 'ready') {
        ctx.fillStyle = 'rgba(2,6,23,0.55)';
        ctx.fillRect(0, 0, W, H);
        ctx.fillStyle = '#f8fafc';
        ctx.font = 'bold 28px Arial';
        ctx.textAlign = 'center';
        ctx.fillText('Space Storm Invaders', W / 2, H / 2 - 24);
        ctx.font = '16px Arial';
        ctx.fillText('Click or press Enter to start', W / 2, H / 2 + 8);
        ctx.fillText('Bosses arrive, and 1000 power-ups rain every 5 seconds', W / 2, H / 2 + 34);
        ctx.textAlign = 'left';
      }
      if (gameState === 'over') {
        ctx.fillStyle = 'rgba(2,6,23,0.62)';
        ctx.fillRect(0, 0, W, H);
        ctx.fillStyle = '#fff';
        ctx.font = 'bold 28px Arial';
        ctx.textAlign = 'center';
        ctx.fillText('Mission Failed', W / 2, H / 2 - 20);
        ctx.font = '16px Arial';
        ctx.fillText(`Score: ${score}`, W / 2, H / 2 + 8);
        ctx.fillText('Press Enter or tap to retry', W / 2, H / 2 + 36);
        ctx.textAlign = 'left';
      }
    }

    function draw() {
      drawBackground();
      drawPowerUps();
      drawEnemies();
      drawBosses();
      drawBullets();
      drawPlayer();
      drawOverlay();
    }

    function loop() {
      update();
      draw();
      requestAnimationFrame(loop);
    }

    canvas.addEventListener('pointerdown', () => {
      if (gameState === 'ready' || gameState === 'over') {
        startGame();
      } else {
        shoot();
      }
    });

    window.addEventListener('keydown', (e) => {
      keys[e.key] = true;
      if (e.code === 'Space') {
        e.preventDefault();
        shoot();
      }
      if (e.code === 'Enter') {
        e.preventDefault();
        if (gameState === 'ready' || gameState === 'over') {
          startGame();
        }
      }
    });

    window.addEventListener('keyup', (e) => {
      keys[e.key] = false;
    });

    resetStars();
    resetGame();
    loop();
  </script>
</body>
</html>
